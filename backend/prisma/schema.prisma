// East Medical Assistance System — Database Schema
// Maps to TPA_System_Analysis.docx sections 3 (Functional Requirements) & 5 (Data Requirements)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────

enum UserRole {
  CASE_MANAGER
  MEDICAL_STAFF
  FINANCE
  ADMIN
  VIEWER
}

enum CaseStatus {
  NEW
  HAS_SERVICE
  ASSIST_CLOSE
  MONEY_PROCESS
  CLOSED
  CANCELLED
}

enum CaseType {
  MEDICAL
  DENTAL
  TRAVEL
  LEGAL
  OTHER
}

enum CaseTypeDetail {
  SIMPLE_MEDICAL_OUTPATIENT
  LIGHT_ASSISTANCE_CASE
  HOSPITALIZATION
  EMERGENCY
  REPATRIATION
  EVACUATION
  OTHER
}

enum ArrivalChannel {
  PHONE
  EMAIL
  PORTAL
  APP
  WALK_IN
  OTHER
}

enum CaseServiceStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum DocumentCategory {
  MEDICAL_REPORT
  LAB_REPORT
  POLICY
  PASSPORT
  INVOICE
  OTHER
}

enum PaymentStatus {
  PENDING
  PROCESSED
  PAID
  REJECTED
}

enum Currency {
  EUR
  EGP
  USD
  GBP
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  VIEW
}

// ─────────────────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  fullName     String
  role         UserRole
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations — things this user created/modified
  casesCreated      Case[]            @relation("CaseCreatedBy")
  casesAssigned     Case[]            @relation("CaseAssignedTo")
  documentsUploaded Document[]
  auditLogs         AuditLog[]
  refreshTokens     RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────
// AUDIT LOG (tamper-evident, append-only)
// ─────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  entityType String // e.g. "Case", "Document", "User"
  entityId   String?
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  details    Json? // before/after diff or extra context
  ipAddress  String?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────
// PATIENTS (Insured)
// ─────────────────────────────────────────────────────────

model Patient {
  id              String   @id @default(uuid())
  fullName        String
  dateOfBirth     DateTime?
  gender          String?
  nationality     String?
  passportNumber  String?
  policyNumber    String?
  phone           String?
  email           String?
  address         String?
  emergencyContact String?

  // Geo detail — matches standard TPA granularity (Country/Province/County/District)
  country  String?
  province String?
  county   String?
  district String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cases Case[]

  @@map("patients")
}

// ─────────────────────────────────────────────────────────
// INSURANCE CONTRACTS
// ─────────────────────────────────────────────────────────

model Contract {
  id               String   @id @default(uuid())
  contractNumber   String   @unique
  insurerName      String
  startDate        DateTime
  endDate          DateTime
  deductiblePct    Decimal  @default(0) @db.Decimal(5, 2)
  guaranteedAmount Decimal? @db.Decimal(14, 2)
  currency         Currency @default(EUR)
  isActive         Boolean  @default(true)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cases Case[]

  @@map("contracts")
}

// ─────────────────────────────────────────────────────────
// PROVIDERS (hospitals, clinics, doctors)
// ─────────────────────────────────────────────────────────

model Provider {
  id          String   @id @default(uuid())
  name        String
  type        String // hospital, clinic, doctor, pharmacy, ambulance, etc.
  country     String
  city        String?
  phone       String?
  email        String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  caseServices CaseService[]

  @@map("providers")
}

// ─────────────────────────────────────────────────────────
// CASES (the core entity)
// ─────────────────────────────────────────────────────────

model Case {
  id           String     @id @default(uuid())
  caseNumber   String     @unique // server-generated, not client-generated
  status       CaseStatus @default(NEW)
  isUrgent     Boolean    @default(false)

  // Case classification (matches standard TPA: Case Type / Case Type Detail)
  caseType       CaseType?
  caseTypeDetail CaseTypeDetail?
  arrivalChannel ArrivalChannel?

  // Caller / intake info (who reported the case, distinct from the patient)
  callerName      String?
  callerPhone     String?
  callerEmail     String?
  countryCode     String?
  tourAgency      String?
  customerReference String?
  description     String? // free-text case description shown at intake
  noteForProforma String?

  // Warranty
  warrantyStatus   String?
  warrantyCurrency Currency?
  warrantyLimitAmount Decimal? @db.Decimal(14, 2)

  // Document checklist flags (Yes/No indicators seen in the standard system)
  hasMedicalReport  Boolean @default(false)
  hasMedicalExpenses Boolean @default(false)
  hasPolicyDoc      Boolean @default(false)
  hasPassportDoc    Boolean @default(false)

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id])

  createdById String
  createdBy   User   @relation("CaseCreatedBy", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("CaseAssignedTo", fields: [assignedToId], references: [id])

  // Case cloning lineage
  clonedFromId String?
  clonedFrom   Case?   @relation("CaseClone", fields: [clonedFromId], references: [id])
  clones       Case[]  @relation("CaseClone")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  closedAt  DateTime?

  medicalInfo  MedicalInfo?
  diagnoses    CaseDiagnosis[]
  caseServices CaseService[]
  documents    Document[]
  notes        CaseNote[]
  activities   CaseActivity[]

  @@map("cases")
}

// Structured diagnosis list (replaces free-text diagnosis field) — matches
// the standard system's multi-select "Diagnose" panel with ICD codes.
model CaseDiagnosis {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  label     String // e.g. "UPPER RESPIRATORY TRACT INFECTION"
  icdCode   String?
  notes     String?
  createdAt DateTime @default(now())

  @@map("case_diagnoses")
}

// Auto-generated system activity feed (e.g. "Case created by X for Account Y"),
// distinct from manually-entered CaseNote.
model CaseActivity {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  message   String
  createdAt DateTime @default(now())

  @@map("case_activities")
}

model MedicalInfo {
  id            String   @id @default(uuid())
  caseId        String   @unique
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  diagnosis     String?
  icdCode       String?
  symptoms      String?
  treatmentPlan String?
  attendingDoctor String?
  admissionDate DateTime?
  dischargeDate DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("medical_info")
}

model CaseNote {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorId  String?
  content   String
  createdAt DateTime @default(now())

  @@map("case_notes")
}

// ─────────────────────────────────────────────────────────
// CASE SERVICES & FINANCIALS
// ─────────────────────────────────────────────────────────

model CaseService {
  id         String             @id @default(uuid())
  caseId     String
  case       Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  providerId String?
  provider   Provider?          @relation(fields: [providerId], references: [id])

  serviceType String // consultation, surgery, lab test, medication, transport, etc.
  description String?
  status      CaseServiceStatus @default(PENDING)

  // Financials
  priceIn        Decimal  @db.Decimal(14, 2) // cost from provider
  priceOut       Decimal  @db.Decimal(14, 2) // billed to insurer
  currency       Currency @default(EUR)
  exchangeRate   Decimal  @default(1) @db.Decimal(10, 6) // rate to base currency at time of entry
  discountPct    Decimal  @default(0) @db.Decimal(5, 2)
  deductionAmount Decimal @default(0) @db.Decimal(14, 2)

  serviceDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items     CaseServiceItem[]
  documents Document[]
  invoice   Invoice?
  payment   Payment?

  @@map("case_services")
}

model CaseServiceItem {
  id            String      @id @default(uuid())
  caseServiceId String
  caseService   CaseService @relation(fields: [caseServiceId], references: [id], onDelete: Cascade)
  description   String
  quantity      Int         @default(1)
  unitPrice     Decimal     @db.Decimal(14, 2)
  currency      Currency    @default(EUR)
  createdAt     DateTime    @default(now())

  @@map("case_service_items")
}

// ─────────────────────────────────────────────────────────
// INVOICING & PAYMENTS (Money Process)
// ─────────────────────────────────────────────────────────

model Invoice {
  id            String      @id @default(uuid())
  invoiceNumber String      @unique
  caseServiceId String      @unique
  caseService   CaseService @relation(fields: [caseServiceId], references: [id])
  amount        Decimal     @db.Decimal(14, 2)
  currency      Currency    @default(EUR)
  issuedAt      DateTime    @default(now())
  dueDate       DateTime?
  pdfUrl        String?

  @@map("invoices")
}

model PaymentGroup {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  payments  Payment[]

  @@map("payment_groups")
}

model Payment {
  id             String        @id @default(uuid())
  caseServiceId  String        @unique
  caseService    CaseService   @relation(fields: [caseServiceId], references: [id])
  paymentGroupId String?
  paymentGroup   PaymentGroup? @relation(fields: [paymentGroupId], references: [id])
  status         PaymentStatus @default(PENDING)
  amount         Decimal       @db.Decimal(14, 2)
  currency       Currency      @default(EUR)
  paymentRef     String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("payments")
}

// ─────────────────────────────────────────────────────────
// DOCUMENTS
// ─────────────────────────────────────────────────────────

model Document {
  id            String           @id @default(uuid())
  caseId        String
  case          Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseServiceId String?
  caseService   CaseService?     @relation(fields: [caseServiceId], references: [id])

  category   DocumentCategory
  fileName   String
  fileUrl    String // storage key/URL, not raw bytes
  fileSize   Int // bytes
  mimeType   String
  version    Int              @default(1)
  isDeleted  Boolean          @default(false) // soft delete

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())

  @@map("documents")
}
