# Standalone backend dev .env (used when running backend directly, not via docker-compose)
DATABASE_URL="postgresql://postgres:password@localhost:5432/east_medical_tpa"

JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# AES-256 key — 32 bytes base64: openssl rand -base64 32
ENCRYPTION_KEY=

MFA_ISSUER=EastMedicalTPA

RETENTION_DAYS=2555

STRIPE_WEBHOOK_SECRET=
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=   # Paymob Dashboard → Developers → HMAC Secret
HOSPITAL_API_URL=
HOSPITAL_API_KEY=
