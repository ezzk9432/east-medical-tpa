# Copy this file to .env and fill in real values. Never commit .env itself.

# Postgres connection string
# Example local: postgresql://postgres:password@localhost:5432/east_medical_tpa
# Example Supabase/Neon: postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/east_medical_tpa"

# JWT secrets — generate strong random strings, e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"

# Token lifetimes
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# CORS — your frontend dev URL
CORS_ORIGIN="http://localhost:5173"
