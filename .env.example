# ─── Database ────────────────────────────────────────────
DB_PASSWORD=changeme_strong_password_here

# ─── JWT Secrets ─────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_with_long_random_string_access
JWT_REFRESH_SECRET=replace_with_long_random_string_refresh

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Frontend Origin (for CORS) ──────────────────────────
CORS_ORIGIN=http://localhost

# ─── Field-Level Encryption (AES-256) ───────────────────
# Generate: openssl rand -base64 32
# Leave empty to disable encryption (dev only!)
ENCRYPTION_KEY=

# ─── MFA ─────────────────────────────────────────────────
MFA_ISSUER=EastMedicalTPA

# ─── Data Retention ──────────────────────────────────────
# Days after case closure before PII is anonymised (default 7 years)
RETENTION_DAYS=2555
# Cron schedule for retention job (default: 2am UTC daily)
RETENTION_CRON=0 2 * * *

# ─── Payment Gateway Integrations ────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_...
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=   # Paymob Dashboard → Developers → HMAC Secret (separate from API key)

# ─── Hospital System Integration ─────────────────────────
HOSPITAL_API_URL=https://your-hospital-system.example.com/api/v1
HOSPITAL_API_KEY=
